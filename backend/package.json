{
  "name": "betting-platform-backend",
  "version": "1.0.0",
  "description": "Betting platform backend API",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate --schema=./prisma/schema.prisma && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prestart": "node -e \"if(!require('fs').existsSync('dist')){require('child_process').execSync('npm run build',{stdio:'inherit'})}\"",
    "lint": "eslint . --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx src/db/seed.ts",
    "prepare": "npm run build",
    "postinstall": "node -e \"if(process.env.SKIP_PRISMA_GENERATE==='true'){console.log('SKIP_PRISMA_GENERATE is set; skipping prisma generate')}else{try{require('child_process').execSync('prisma generate --schema=./prisma/schema.prisma',{stdio:'inherit'})}catch(e){console.warn('prisma generate failed during postinstall; continuing without failing build')} }\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "@prisma/client": "^5.7.1",
    "zod": "^3.22.4",
    "axios": "^1.6.2",
    "socket.io": "^4.7.2",
    "stripe": "^13.0.0",
    "express-rate-limit": "^7.1.5",
    "redis": "^4.6.12",
    "uuid": "^9.0.1",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "prisma": "^5.7.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.11"
  }
}
